# RPC URL for the network (Sepolia/Base Sepolia/local)
RPC_URL=https://sepolia.drpc.org

# Private key used by the relayer to pay gas
SUBSIDY_PRIVATE_KEY=0xYOUR_SUBSIDY_PRIVATE_KEY

# FireCoin contract address on the chosen network
CONTRACT_ADDRESS=0xYourDeployedAddress

# Optional: server port
PORT=8787
